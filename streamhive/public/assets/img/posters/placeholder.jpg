<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 300" width="200" height="300">
  <rect width="200" height="300" fill="#1a1a1a"/>
  <rect width="200" height="300" fill="url(#gradPlaceholder)" opacity="0.5"/>
  <defs>
    <linearGradient id="gradPlaceholder" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#20c997;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#8e44ad;stop-opacity:0.3" />
    </linearGradient>
  </defs>
  <text x="100" y="130" font-size="20" font-weight="bold" text-anchor="middle" fill="#666">Movie Poster</text>
  <text x="100" y="160" font-size="14" text-anchor="middle" fill="#999">Placeholder Image</text>
  <circle cx="100" cy="240" r="12" fill="#20c997" opacity="0.5"/>
</svg>
